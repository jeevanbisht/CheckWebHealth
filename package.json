{
  "name": "scenario-recorder",
  "version": "1.0.0",
  "description": "Probe a catalog of sites through a SASE/GSA tunnel to detect CDN/WAF bot-blocking and render an HTML report",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "playwright install chromium msedge",
    "sample": "node probe-sample.mjs",
    "probe": "node probe-catalog.mjs",
    "evidence": "node probe-evidence.mjs",
    "report": "node render-catalog-html.mjs",
    "all": "node probe-catalog.mjs && node render-catalog-html.mjs"
  },
  "dependencies": {
    "playwright": "^1.49.0"
  },
  "engines": {
    "node": ">=18"
  }
}
